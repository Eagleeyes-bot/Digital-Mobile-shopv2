# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_API_KEY: Optional if not using OAuth
GOOGLE_API_KEY="MY_GOOGLE_API_KEY"

# GOOGLE_SHEET_ID: The ID of your Google Sheet database
GOOGLE_SHEET_ID="MY_GOOGLE_SHEET_ID"

# GOOGLE_DRIVE_FOLDER_ID: The folder ID for product images
GOOGLE_DRIVE_FOLDER_ID="MY_GOOGLE_DRIVE_FOLDER_ID"

# GOOGLE_CLIENT_ID: OAuth2 Client ID
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"

# GOOGLE_CLIENT_SECRET: OAuth2 Client Secret
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"

# GOOGLE_REFRESH_TOKEN: OAuth2 Refresh Token
GOOGLE_REFRESH_TOKEN="MY_GOOGLE_REFRESH_TOKEN"
